{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "Audio Output Swap",
  "Version": "1.0.0.0",
  "Author": "Welsh",
  "URL": "https://github.com/brendanwelsh/streamdeck-audioswap",
  "Description": "Swap the Windows default audio output between two devices (press) and control master volume (rotate) from a Stream Deck+ dial.",
  "Category": "Audio Output Swap",
  "CategoryIcon": "imgs/category",
  "Icon": "imgs/plugin-icon",
  "SDKVersion": 2,
  "CodePath": "plugin.js",
  "Nodejs": { "Version": "24", "Debug": "enabled" },
  "Software": { "MinimumVersion": "6.4" },
  "OS": [ { "Platform": "windows", "MinimumVersion": "10" } ],
  "Actions": [
    {
      "Name": "Audio Output",
      "UUID": "com.welsh.audioswap.output",
      "Icon": "imgs/action-audio",
      "PropertyInspectorPath": "pi/audio.html",
      "Tooltip": "Press to swap the default output device, rotate for master volume",
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "layouts/audiodial.json",
        "TriggerDescription": { "Rotate": "Master volume", "Push": "Swap output device" }
      },
      "States": [ { "Image": "imgs/action-audio", "TitleAlignment": "middle" } ]
    }
  ]
}
